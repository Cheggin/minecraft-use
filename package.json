{
  "name": "@reaganhsu/minecraft-code",
  "version": "0.1.1",
  "description": "Turn Minecraft into a terminal for AI agents. Spawn Claude Code as a villager, find schematics on the web, and build them in your world — all from in-game chat.",
  "keywords": [
    "minecraft",
    "fabric",
    "claude",
    "claude-code",
    "ai",
    "ai-agent",
    "tmux",
    "browser-use",
    "llm",
    "agent",
    "schematics",
    "litematica",
    "villager",
    "coding",
    "terminal"
  ],
  "homepage": "https://github.com/Cheggin/minecraft-use",
  "repository": {
    "type": "git",
    "url": "https://github.com/Cheggin/minecraft-use.git"
  },
  "license": "MIT",
  "bin": {
    "minecraft-code": "./bin/cli.js"
  },
  "files": [
    "bin/",
    "lib/",
    "fabric-mod/src/",
    "fabric-mod/build.gradle",
    "fabric-mod/settings.gradle",
    "fabric-mod/gradle.properties",
    "fabric-mod/gradle/",
    "fabric-mod/gradlew",
    "fabric-mod/gradlew.bat",
    "sidecar/*.py",
    "sidecar/requirements.txt",
    "sidecar/requirements-dev.txt",
    "sidecar/pyproject.toml",
    "sidecar/tests/",
    "Taskfile.yml",
    "run.sh"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
